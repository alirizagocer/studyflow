{
  "name": "studyflow",
  "version": "1.0.0",
  "description": "Akıllı Öğrenci Üretkenlik Sistemi",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder",
    "test": "vitest"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "zustand": "^4.5.2",
    "recharts": "^2.12.4",
    "@tanstack/react-query": "^5.36.0",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.studyflow.app",
    "productName": "StudyFlow",
    "directories": {
      "buildResources": "electron/assets",
      "output": "dist-electron"
    },
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!**/__pycache__/**", "!**/*.pyc", "!**/tests/**"]
      }
    ],
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Education"
    },
    "extraMetadata": {
      "main": "electron/main.js"
    }
  }
}