# backend/.env.example
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# cp .env.example .env

# ── Uygulama ──────────────────────────────────────────────────────────────────
APP_NAME=StudyFlow
DEBUG=true
ENVIRONMENT=development

# ── Veritabanı ────────────────────────────────────────────────────────────────
# SQLite (başlangıç için — ücretsiz, kurulum gerektirmez)
DATABASE_URL=sqlite+aiosqlite:///./studyflow.db

# PostgreSQL'e geçmek için (ölçeklenince):
# DATABASE_URL=postgresql+asyncpg://studyflow:SIFRE@localhost:5432/studyflow

# ── Güvenlik ──────────────────────────────────────────────────────────────────
# openssl rand -hex 32 ile üret
SECRET_KEY=CHANGE_THIS_BEFORE_PRODUCTION

# ── Takvim Senkronizasyonu ────────────────────────────────────────────────────
# Yerel ağdaki IP adresiniz (telefon ve bilgisayar aynı WiFi'da olmalı)
# Terminalde: ipconfig (Windows) veya ifconfig (Mac) ile öğrenin
CALENDAR_BASE_URL=http://192.168.1.X:8000
